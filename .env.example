# ─── Copy this file to .env and fill in your keys ────────────────────────────
# cp .env.example .env

# Meta Ad Library API
# Apply at: https://www.facebook.com/ads/library/api/
META_ACCESS_TOKEN=your_meta_token_here

# YouTube Data API v3
# Get free key at: https://console.cloud.google.com → Enable "YouTube Data API v3"
YOUTUBE_API_KEY=your_youtube_api_key_here

# Apify (for Instagram scraping)
# Get token at: https://apify.com → Settings → Integrations
APIFY_TOKEN=your_apify_token_here

# Server port (optional, defaults to 3001)
PORT=3001
