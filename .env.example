# ─── Copy this file to .env and fill in your keys ────────────────────────────
# cp .env.example .env

# SearchAPI (for Meta Ad Library — Facebook + Instagram ads)
# Get key at: https://www.searchapi.io → Dashboard → API Key
# No Meta developer approval needed — works immediately.
SEARCHAPI_KEY=your_searchapi_key_here

# YouTube Data API v3
# Get free key at: https://console.cloud.google.com → Enable "YouTube Data API v3"
# In API key restrictions, select "YouTube Data API v3"
YOUTUBE_API_KEY=your_youtube_api_key_here

# Apify (for Instagram organic scraping)
# Get token at: https://apify.com → Settings → Integrations
# Actor used: apify/instagram-scraper
APIFY_TOKEN=your_apify_token_here

# Server port (optional, defaults to 3001)
PORT=3001
